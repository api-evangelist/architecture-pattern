{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/architecture-pattern/refs/heads/main/json-schema/architecture-pattern-api-domain-list-schema.json",
  "title": "DomainList",
  "type": "object",
  "properties": {
    "total": {
      "type": "integer"
    },
    "domains": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {},
          "name": {},
          "description": {},
          "patternCount": {},
          "subdomains": {}
        }
      }
    }
  }
}