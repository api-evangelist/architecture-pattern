{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/architecture-pattern/refs/heads/main/json-schema/architecture-pattern-api-tradeoff-schema.json",
  "title": "Tradeoff",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "patternId": {
      "type": "string"
    },
    "dimension": {
      "type": "string"
    },
    "benefit": {
      "type": "string"
    },
    "drawback": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "notes": {
      "type": "string"
    }
  }
}